@page "/"
@inject ICategoryService CategoryService
@inject IProductService  ProductService

<PageTitle>PhoneShop – Home</PageTitle>

<h1>Welcome to PhoneShop</h1>

@if (_loading)
{
    <p>Loading…</p>
}
else
{
    <section class="section">
        <h2>Categories</h2>
        <div class="category-grid">
            @foreach (var cat in _categories)
            {
                <a href="/category/@cat.Id" class="category-card">
                    <strong>@cat.Name</strong>
                    <p>@cat.Description</p>
                </a>
            }
        </div>
    </section>

    <section class="section">
        <h2>All Phones</h2>
        <div class="product-grid">
            @foreach (var p in _products)
            {
                <a href="/product/@p.Id" class="product-card">
                    @if (!string.IsNullOrEmpty(p.ImageUrl))
                    {
                        <img src="@p.ImageUrl" alt="@p.Name" loading="lazy" />
                    }
                    <h3>@p.Name</h3>
                    <p class="brand">@p.Brand</p>
                    <p class="price">$@p.Price.ToString("F2")</p>
                </a>
            }
        </div>
    </section>
}

@code {
    private List<CategoryDto> _categories = [];
    private List<ProductDto>  _products   = [];
    private bool              _loading    = true;

    protected override async Task OnInitializedAsync()
    {
        (_categories, _products) = await (
            CategoryService.GetCategoriesAsync(),
            ProductService.GetProductsAsync());
        _loading = false;
    }
}
