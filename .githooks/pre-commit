#!/usr/bin/env bash

set -euo pipefail

# Default strict frameworks: React,Vue,Tailwind
# Example customization:
#   pwsh ... -File scripts/ui-precommit-check.ps1 -Strict -StrictFrameworks React,Vue

if command -v pwsh >/dev/null 2>&1; then
  pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/ui-precommit-check.ps1 -Strict
elif command -v powershell >/dev/null 2>&1; then
  powershell -NoProfile -ExecutionPolicy Bypass -File scripts/ui-precommit-check.ps1 -Strict
else
  echo "Skipping UI checks: PowerShell is not available."
fi
